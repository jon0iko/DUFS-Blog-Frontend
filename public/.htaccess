# Apache configuration for DUFS Blog Frontend
# Two-tier serving: Humans get the dynamic Next.js app, Bots get static SEO pages

Options -Indexes
Options +FollowSymLinks

<IfModule mod_rewrite.c>
RewriteEngine On

# 1. Detect search engine bots and crawlers
# Extended list to cover all major social and search bots
SetEnvIfNoCase User-Agent "googlebot|bingbot|slurp|duckduckbot|baiduspider|yandexbot|sogou|exabot|facebookexternalhit|facebot|ia_archiver" IS_BOT

# BOT RULES: Serve static index.html snapshots generated by mjs script
RewriteCond %{ENV:IS_BOT} =1

# Rule: Articles -> /articles/<slug>/index.html
RewriteCond %{REQUEST_URI} ^/articles/([^/]+)/?$ [NC]
RewriteCond %{DOCUMENT_ROOT}/articles/%1/index.html -f
RewriteRule ^articles/([^/]+)/?$ /articles/$1/index.html [L]

# Rule: Authors -> /authors/<slug>/index.html
RewriteCond %{REQUEST_URI} ^/authors/([^/]+)/?$ [NC]
RewriteCond %{DOCUMENT_ROOT}/authors/%1/index.html -f
RewriteRule ^authors/([^/]+)/?$ /authors/$1/index.html [L]

# Rule: Categories (EN) -> /browse/<slug>/en/index.html
# Note: Checks for query param since sitemap uses /browse?category=slug
RewriteCond %{QUERY_STRING} category=([^&]+) [NC]
RewriteCond %{DOCUMENT_ROOT}/browse/%1/en/index.html -f
RewriteRule ^browse$ /browse/%1/en/index.html [L]


# HUMAN RULES: Route to dynamic components
# Do not rewrite if the physical file exists (serves sitemap.xml, images, etc. directly)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Human Articles -> Use the universal reader
RewriteRule ^articles/([^/]+)/?$ /read-article?slug=$1 [L,QSA]

# Human Authors -> Route to authors page with slug
RewriteRule ^authors/([^/]+)/?$ /authors?slug=$1 [L,QSA]

# Human Browse/Categories
RewriteRule ^browse/([^/]+)/?$ /browse?category=$1 [L,QSA]

# Fallback to index.html for SPA routing (standard Next.js export behavior)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  # Optional: Recommended for DUFS to ensure HTTPS
  # Header always set Content-Security-Policy "upgrade-insecure-requests;"
</IfModule>

# Caching for static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

# Compression for faster loading
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>